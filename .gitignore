# Données sensibles — ne jamais versionner

# Secrets Streamlit (credentials DB, mot de passe…) — NE JAMAIS COMMITER
.streamlit/secrets.toml


# Documents internes — accessibles uniquement via l'application
assets/*
!assets/cahier_des_charges.html
data/*
!data/cahier_des_charges.json

help suivi.txt
# Environnements Python
__pycache__/
*.py[cod]
.env
frontend/.env
venv/
.venv/

# Frontend Vue/Vite
frontend/node_modules/
frontend/dist/

# PyInstaller
dist/
build/
*.spec

# Stocker uniquement le hash SHA-256 du mot de passe (jamais le mot de passe en clair).
# Pour générer un nouveau hash : python -c "import hashlib; print(hashlib.sha256('VOTRE_MDP'.encode()).hexdigest())"