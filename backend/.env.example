# Copier ce fichier en .env et remplir les valeurs AVANT de lancer le serveur.
# Ce fichier .env.example peut être versionné. Le .env réel ne doit PAS l'être.

# ── Base de données ───────────────────────────────────────────────────────────
# Format asyncpg (sans +asyncpg dans l'URL — asyncpg le gère nativement)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/AppGDP

# ── JWT ───────────────────────────────────────────────────────────────────────
# Générer une vraie clé avec :
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REMPLACER_PAR_UNE_VRAIE_CLE_SECRETE_MIN_32_CHARS

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── Mot de passe admin ────────────────────────────────────────────────────────
# Hash SHA-256 — doit correspondre à PASSWORD_HASH dans .streamlit/secrets.toml
# Générer :
#   python -c "import hashlib; print(hashlib.sha256('MON_MDP'.encode()).hexdigest())"
PASSWORD_HASH=ac9689e2272427085e35b9d3e3e8bed88cb3434828b43b86fc0596cad4c6e270

# ── CORS ──────────────────────────────────────────────────────────────────────
# URLs du frontend autorisées (dev local + prod Vercel)
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ── Base de données : SSL ─────────────────────────────────────────────────────
# Mettre "true" pour Supabase / toute DB cloud, "false" pour Postgres local
DB_SSL=false

# ── Cookies d'authentification ────────────────────────────────────────────────
# En prod cross-site (frontend Vercel ↔ backend Render) :
#   COOKIE_SECURE=true
#   COOKIE_SAMESITE=none
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
